# Database
DATABASE_URL=postgresql://socuser:socpassword@localhost:5432/socanalyzer

# Backend
PORT=4000
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change-this-to-a-long-random-secret

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# LLM Provider (optional)
# Default provider is anthropic. Set LLM_PROVIDER to switch providers.
# Supported: anthropic | openai | deepseek | llama
LLM_PROVIDER=anthropic

# Optional generic overrides (work for any provider)
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=

# OpenAI GPT (when LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek-R1 (when LLM_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-reasoner
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Llama (when LLM_PROVIDER=llama) — typically an OpenAI-compatible server
# For Ollama: start `ollama serve` and use:
# LLAMA_BASE_URL=http://localhost:11434/v1
# LLAMA_MODEL=llama3.1
# LLAMA_API_KEY=   # often not required

# NextAuth (Frontend)
NEXTAUTH_SECRET=change-this-to-another-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# Backend URL (used server-side by Next.js)
BACKEND_URL=http://localhost:4000

# Backend URL (used client-side in browser — must be NEXT_PUBLIC_)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
