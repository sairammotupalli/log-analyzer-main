// SOC Log Analyzer - Prisma Schema
// Database: PostgreSQL 16
// ORM: Prisma 6.x

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// NEXTAUTH REQUIRED TABLES
// ─────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?   // null for OAuth-only users
  activeProvider String    @default("anthropic") // which LLM provider is currently selected
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  uploads LogUpload[]
  llmConfigs UserLlmConfig[]

  @@map("users")
}

model UserLlmConfig {
  id        String   @id @default(cuid())
  userId    String
  provider  String   @default("anthropic")
  model     String?
  baseUrl   String?

  // Stored encrypted (AES-256-GCM) as: base64(iv).base64(tag).base64(ciphertext)
  apiKeyEnc String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("user_llm_configs")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// APPLICATION TABLES
// ─────────────────────────────────────────────

model LogUpload {
  id           String       @id @default(cuid())
  userId       String
  filename     String       // stored filename on disk (uuid-based)
  originalName String       // user's original filename
  fileSize     Int          // in bytes
  status       UploadStatus @default(PENDING)
  totalEntries Int          @default(0)
  errorMessage String?      // populated on FAILED status
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   LogEntry[]
  analysis  AnalysisResult?
  history   AnalysisHistory[]
  anomalies Anomaly[]

  @@index([userId])
  @@index([status])
  @@map("log_uploads")
}

enum UploadStatus {
  PENDING
  PARSING
  ANALYZING
  COMPLETE
  FAILED
}

model LogEntry {
  id        String   @id @default(cuid())
  uploadId  String
  createdAt DateTime @default(now())

  // ── Core Transaction ──────────────────────
  timestamp  DateTime // parsed from `time` field
  proto      String?  // HTTP / HTTPS
  reqmethod  String?  // GET / POST / PUT etc.
  url        String?  @db.Text
  respcode   String?  // HTTP response code

  // ── User & Device ─────────────────────────
  login    String? // user email / login name
  dept     String? // department
  location String? // network location

  // ── Network ───────────────────────────────
  cip String? // client (source) IP
  sip String? // server (destination) IP
  ua  String? @db.Text // user agent

  // ── Action & Policy ───────────────────────
  action    String? // Allowed / Blocked
  ruletype  String? // FwFilter etc.
  rulelabel String? // rule name

  // ── Threat & Risk ─────────────────────────
  threatname    String? // EICAR / Adware.Gen / null
  malwarecat    String? // Spyware / Ransomware / null
  riskscore     Int?    // 0–100
  threatseverity String? // Critical / High / null
  reason        String? // reason for action

  // ── URL Categorization ────────────────────
  urlsupercat String? // broad category
  urlcat      String? // specific category
  urlsubcat   String? // sub-category
  appname     String? // cloud app name
  appclass    String? // app classification

  // ── Size / Traffic ────────────────────────
  reqsize      Int? // total request size (bytes)
  respsize     Int? // total response size (bytes)
  reqdatasize  Int? // request data size (bytes)
  respdatasize Int? // response data size (bytes)
  contenttype  String? // MIME content type

  // ── SSL / DLP ─────────────────────────────
  keyprotectiontype String?
  ssldecrypted      String? // Yes / No
  dlpeng            String? // DLP engine
  dlpdict           String? // DLP dictionary
  unscannabletype   String?

  // ── Anomaly Flag ──────────────────────────
  isAnomalous Boolean @default(false)

  // ── Raw backup ────────────────────────────
  rawData Json // full parsed row as JSON

  upload    LogUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  anomalies Anomaly[]

  @@index([uploadId, timestamp])
  @@index([uploadId, cip])
  @@index([uploadId, isAnomalous])
  @@index([uploadId, action])
  @@map("log_entries")
}

model AnalysisResult {
  id       String @id @default(cuid())
  uploadId String @unique
  provider String @default("anthropic") // which LLM produced the current result

  // ── AI Generated Content ──────────────────
  executiveSummary   String  @db.Text
  timeline           Json    // TimelineEvent[]
  stats              Json    // AggregatedStats
  topThreats         Json    // ThreatEntry[]
  socRecommendations Json    // string[]

  // ── Aggregate Counts ──────────────────────
  totalRequests   Int
  blockedRequests Int
  threatCount     Int
  anomalyCount    Int
  uniqueUsers     Int
  uniqueIPs       Int

  // ── Time Range ────────────────────────────
  timeRangeStart DateTime?
  timeRangeEnd   DateTime?

  createdAt DateTime @default(now())

  upload LogUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@map("analysis_results")
}

// Stores every past AI analysis run for an upload so users can browse history.
model AnalysisHistory {
  id       String @id @default(cuid())
  uploadId String
  provider String // LLM that produced this run

  // ── AI Generated Content ──────────────────
  executiveSummary   String  @db.Text
  timeline           Json
  stats              Json
  topThreats         Json
  socRecommendations Json

  // ── Aggregate Counts ──────────────────────
  totalRequests   Int
  blockedRequests Int
  threatCount     Int
  anomalyCount    Int
  uniqueUsers     Int
  uniqueIPs       Int

  timeRangeStart DateTime?
  timeRangeEnd   DateTime?

  createdAt DateTime @default(now())

  upload LogUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId, createdAt])
  @@map("analysis_history")
}

model Anomaly {
  id          String       @id @default(cuid())
  uploadId    String
  logEntryId  String?      // null for aggregate anomalies (e.g. IP rate)
  type        AnomalyType
  severity    Severity
  description String       @db.Text // human-readable explanation
  confidenceScore Float    // 0.0 – 1.0
  affectedIp  String?
  affectedUser String?
  details     Json         // supporting data (counts, time windows, etc.)
  createdAt   DateTime     @default(now())

  upload    LogUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  logEntry  LogEntry? @relation(fields: [logEntryId], references: [id], onDelete: SetNull)

  @@index([uploadId])
  @@index([uploadId, severity])
  @@map("anomalies")
}

enum AnomalyType {
  HIGH_REQUEST_RATE
  REPEATED_BLOCK
  THREAT_DETECTED
  HIGH_RISK_SCORE
  SUSPICIOUS_UA
  OFF_HOURS_ACCESS
  LARGE_TRANSFER
  MALICIOUS_CATEGORY
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
