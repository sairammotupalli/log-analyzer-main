# Copy to .env and fill in. Used by docker compose.
# Secrets are NOT injected — pass via .env or docker run -e

# Required for production (optional for dev — auto-generated if empty)
JWT_SECRET=
NEXTAUTH_SECRET=

# Google OAuth — from https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (docker-compose overrides for container network)
DATABASE_URL=postgresql://socuser:socpassword@localhost:5432/socanalyzer

# URLs
NEXTAUTH_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Optional: LLM (or configure per-user in app)
ANTHROPIC_API_KEY=
